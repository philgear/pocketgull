---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// Filter out h1 (title) and only show h2 and h3
const tocHeadings = headings.filter((h) => h.depth > 1 && h.depth < 4);
---

{tocHeadings.length > 0 && (
  <nav class="toc-nav">
    <div class="toc-header">On This Page</div>
    <ul class="toc-list">
      {tocHeadings.map((heading) => (
        <li class={`toc-item depth-${heading.depth}`}>
          <a href={`#${heading.slug}`} class="toc-link">
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc-nav {
    position: sticky;
    top: 88px;
    padding-left: 1rem;
    border-left: 1px solid var(--pg-border);
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }

  .toc-header {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--pg-text);
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .toc-item {
    line-height: 1.3;
  }

  .depth-3 {
    padding-left: 0.75rem;
  }

  .toc-link {
    display: block;
    font-size: 0.75rem;
    color: var(--pg-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .toc-link:hover {
    color: var(--pg-accent-dark);
    text-decoration: none;
  }

  @media (prefers-color-scheme: dark) {
    .toc-link:hover {
      color: var(--pg-accent-light);
    }
  }

  /* Active state handled by client JS in DocsLayout */
  :global(.toc-link.active) {
    color: var(--pg-accent-dark);
    font-weight: 600;
  }
  @media (prefers-color-scheme: dark) {
    :global(.toc-link.active) {
      color: var(--pg-accent-light);
    }
  }
</style>
