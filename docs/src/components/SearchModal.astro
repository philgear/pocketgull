---
---

<dialog id="searchModal" class="search-modal">
  <div class="search-container">
    <header class="search-header">
      <div id="searchUI"></div>
      <button id="closeSearch" aria-label="Close search" class="search-close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </header>
  </div>
</dialog>

<style>
  .search-modal {
    padding: 0;
    border: none;
    border-radius: 12px;
    background: transparent;
    max-width: 600px;
    width: 100%;
    margin-top: 10vh;
    backdrop-filter: blur(8px);
  }

  .search-modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .search-container {
    background: var(--pg-surface);
    border: 1px solid var(--pg-border);
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    overflow: hidden;
    position: relative;
  }

  .search-header {
    display: flex;
    align-items: flex-start;
  }

  #searchUI {
    flex: 1;
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--pg-accent);
    --pagefind-ui-text: var(--pg-text);
    --pagefind-ui-background: var(--pg-surface);
    --pagefind-ui-border: var(--pg-border);
    --pagefind-ui-tag: var(--pg-bg);
    --pagefind-ui-border-width: 0;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: 'Inter', system-ui, sans-serif;
  }

  .search-close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--pg-text-muted);
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s;
  }

  .search-close:hover {
    color: var(--pg-text);
  }

  /* Override internal Pagefind styles to match our Dieter Rams aesthetic */
  :global(.pagefind-ui__search-input) {
    font-weight: 500 !important;
    border-bottom: 1px solid var(--pg-border) !important;
    border-radius: 0 !important;
  }
  :global(.pagefind-ui__message) {
    padding: 0 20px !important;
    font-size: 0.75rem !important;
    color: var(--pg-text-muted) !important;
  }
  :global(.pagefind-ui__results-area) {
    padding: 0 10px 10px !important;
  }
</style>

<script is:inline>
  window.addEventListener('DOMContentLoaded', () => {
    let initialized = false;
    const modal = document.getElementById('searchModal');
    const closeBtn = document.getElementById('closeSearch');
    const triggerBtn = document.getElementById('searchTrigger');

    function openSearch() {
      modal.showModal();
      initSearch();
      // Focus input
      setTimeout(() => {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input) input.focus();
      }, 50);
    }

    // Trigger open
    triggerBtn?.addEventListener('click', openSearch);

    // Keyboard shortcut Cmd+K or Ctrl+K
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
    });

    // Close logic
    closeBtn?.addEventListener('click', () => modal.close());
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    function initSearch() {
      if (initialized) return;
      
      // Load Pagefind UI dynamically so it doesn't block initial page load
      const link = document.createElement('link');
      link.href = '/docs/pagefind/pagefind-ui.css';
      link.rel = 'stylesheet';
      document.head.appendChild(link);
      
      const script = document.createElement('script');
      script.src = '/docs/pagefind/pagefind-ui.js';
      script.onload = () => {
        new PagefindUI({ 
          element: "#searchUI", 
          showSubResults: true,
          showImages: false,
          baseUrl: '/docs/'
        });
      };
      
      // Handle dev mode gracefully where pagefind hasn't run yet
      script.onerror = () => {
        document.getElementById('searchUI').innerHTML = '<div style="padding: 20px; font-size: 0.8rem; color: #999;">Search index is generated during production builds (`npm run build`). <br/>Run <code>npx pagefind --site dist</code> to test locally.</div>';
      };
      
      document.head.appendChild(script);
      initialized = true;
    }
  });
</script>
