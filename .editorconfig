# EditorConfig helps maintain consistent coding styles for multiple developers/IDEs
# https://editorconfig.org

root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

[*.md]
trim_trailing_whitespace = false

[*.bat]
end_of_line = crlf
