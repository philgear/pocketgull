{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "types": [
      "node",
      "jasmine"
    ],
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "noEmit": false,
    "outDir": "./dist/out-tsc",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@google-cloud/storage": [
        "./src/mocks/empty.ts"
      ]
    }
  },
  "files": [
    "./main.ts",
    "./src/globals.d.ts",
    "./src/main.server.ts",
    "./src/server.ts",
    "./src/server/dicom.ts",
    "./src/server/healthcare.ts",
    "./src/server/fitbit.ts",
    "./src/server/world-health.ts",
    "./src/server/telemetry.ts",
    "./src/server/genkit.ts"
  ],
  "include": [
    "./src/**/*.ts",
    "./main.ts"
  ],
  "angularCompilerOptions": {
    "disableTypeScriptVersionCheck": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/lib/dataconnect/**"
  ]
}