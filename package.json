    "@google/adk": "^0.5.0",
    "@google/genai": "^1.44.0",
    "@mcp-b/webmcp-polyfill": "^2.2.0",
    "@mlc-ai/web-llm": "^0.2.82",
    "@opentelemetry/api": "^1.9.0",
