{
  "name": "pocket-gull",
  "version": "1.0.0",
  "description": "Insight beneath the surface. Real-time medical Care Plan Strategy and Live AI Consult engine powered by Google Gemini.",
  "author": "Phil Gear",
  "license": "MIT",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
