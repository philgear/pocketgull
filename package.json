{
  "name": "pocket-gull",
  "version": "0.2.0",
  "description": "Insight beneath the surface. Real-time medical Care Plan Strategy and Live AI Consult engine powered by Google Gemini.",
  "author": "Phil Gear",
  "keywords": [
    "ai",
    "healthcare",
    "gemini",
    "angular",
    "care-plan",
    "voice-assistant",
    "medical-intake"
  ],
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/philgear/pocket-gull.git"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "browser": {
    "node:buffer": false,
    "node:util": false,
    "node:http": false,
    "node:https": false,
    "node:zlib": false,
    "node:stream": false,
    "node:url": false,
    "node:net": false,
    "node:crypto": false,
    "node:fs": false,
    "node:assert": false,
    "node:tls": false,
    "node:child_process": false,
    "node:os": false,
    "node:process": false,
    "node:path": false,
    "node:events": false,
    "node:async_hooks": false,
    "node:querystring": false,
    "buffer": false,
    "path": false,
    "node-fetch": false,
    "tls": false,
    "assert": false,
    "url": false,
    "fs": false,
    "fs/promises": false,
    "crypto": false,
    "stream": false,
    "util": false,
    "http": false,
    "https": false,
    "zlib": false,
    "child_process": false,
    "os": false,
    "net": false,
    "process": false,
    "events": false,
    "async_hooks": false,
    "querystring": false,
    "@google-cloud/storage": false
  },
  "scripts": {
    "postinstall": "patch-package",
    "build:docs": "npm --prefix docs run build",
    "predev": "npm run build:docs",
    "dev": "npx -y kill-port 4200 & ng serve",
    "prebuild": "npm run build:docs",
    "build": "ng build",
    "test": "node test-api.js && node scripts/test-llm-agent.stub.js && tsc --noEmit",
    "lint": "tsc --noEmit",
    "preview": "npm run build && node dist/server/server.mjs",
    "changelog": "echo \"Remember to update CHANGELOG.md before running npm run release\"",
    "release": "npm run changelog && npm version patch -m \"chore(release): %s\"",
    "deploy": "npm run build && gcloud run deploy pocket-gull-v2 --source . --region=us-west1 --set-secrets=GEMINI_API_KEY=GEMINI_API_KEY:latest --quiet",
    "deploy:secure": "npm run build && gcloud run deploy pocket-gull-secure --source . --region=us-west1 --set-secrets=GEMINI_API_KEY=GEMINI_API_KEY:latest --vpc-egress=all-traffic --ingress=internal-and-cloud-load-balancing --set-env-vars=LOG_LEVEL=warn --quiet",
    "serve:ssr:app": "node dist/server/server.mjs",
    "start": "node dist/server/server.mjs",
    "gcp-build": "npm run build && npm prune --production",
    "audit": "lighthouse http://localhost:4000 --view",
    "estimate-effort": "node scripts/estimate-effort.js"
  },
  "dependencies": {
    "@angular/build": "~21.2.0",
    "@angular/cli": "^21.2.2",
    "@angular/common": "^21.2.3",
