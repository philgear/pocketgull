  "scripts": {
    "postinstall": "patch-package",
    "dev": "ng serve",
    "build": "npm install --prefix docs/study && npm run build --prefix docs/study && ng build",
    "lint": "node node_modules/typescript/lib/tsc.js --noEmit",
    "preview": "npm run build && node dist/server/server.mjs",
    "changelog": "echo \"Remember to update CHANGELOG.md before running npm run release\"",
    "deploy": "echo '⚠️  Production deploys should go through GitHub Actions (deploy.yml). Use npm run deploy:manual if you really need a direct deploy.' && exit 1",
    "deploy:manual": "npm run build && gcloud run deploy pocket-gull --source . --project gen-lang-client-0540208645 --region=us-west1 --set-secrets=\"GEMINI_API_KEY=GEMINI_API_KEY:latest,STRIPE_SECRET_KEY=STRIPE_SECRET_KEY:latest,STRIPE_WEBHOOK_SECRET=STRIPE_WEBHOOK_SECRET:latest,AWS_ACCESS_KEY_ID=AWS_ACCESS_KEY_ID:latest,AWS_SECRET_ACCESS_KEY=AWS_SECRET_ACCESS_KEY:latest,AWS_HEALTHLAKE_ENDPOINT=AWS_HEALTHLAKE_ENDPOINT:latest\" --update-env-vars=OTEL_SDK_DISABLED=true --quiet",
    "serve:ssr:app": "node dist/server/server.mjs",
    "start": "node dist/server/server.mjs",
    "gcp-build": "npm run build && npm prune --production",
    "audit": "lighthouse http://localhost:4000 --view",
    "estimate-effort": "node scripts/estimate-effort.js",
    "estimate-effort:detailed": "node scripts/estimate-effort-detailed.js",
    "precommit": "node scripts/pre-commit-check.cjs",
    "prepare": "husky",
    "test": "vitest run && python3 pocketgull_api/run_tests.py",
    "test:watch": "vitest",
    "test:python": "python3 pocketgull_api/run_tests.py",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "dns:update": "node scripts/update-porkbun-dns.js",
    "kube:start": "minikube start",
    "kube:dev": "skaffold dev",
    "kube:stop": "minikube stop"
  },
