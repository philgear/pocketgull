  "scripts": {
    "postinstall": "patch-package",
    "dev": "ng serve",
    "build": "ng build",
    "lint": "tsc --noEmit",
    "preview": "npm run build && node dist/app/server/server.mjs",
    "start": "node dist/app/server/server.mjs",
    "serve:ssr:app": "node dist/app/server/server.mjs",
    "gcp-build": "npm run build && npm prune --production",
    "deploy": "npm run build && gcloud run deploy pocket-gull-v2 --source . --region=us-central1 --network=default --subnet=default --vpc-egress=private-ranges-only --set-secrets=GEMINI_API_KEY=GEMINI_API_KEY:latest --project=gen-lang-client-0540208645 --quiet",
    "release": "npm version patch -m \"chore(release): %s\"",
    "prepare": "husky"
  },
