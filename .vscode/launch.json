{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CLI: Interactive 510(k) Terminal",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/gull.js",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    },
    {
      "name": "Flutter: Patient App (Default)",
      "request": "launch",
      "type": "dart",
      "program": "companion-apps/patient_app/lib/main.dart"
    },
    {
      "name": "Flutter: Patient App (Local API)",
      "request": "launch",
      "type": "dart",
      "program": "companion-apps/patient_app/lib/main.dart",
      "toolArgs": [
        "--dart-define=API_URL=http://127.0.0.1:4200/api"
      ]
    },
    {
      "name": "Flutter: Provider App (Default)",
      "request": "launch",
      "type": "dart",
      "program": "companion-apps/provider_app/lib/main.dart"
    },
    {
      "name": "Flutter: Provider App (Local API)",
      "request": "launch",
      "type": "dart",
      "program": "companion-apps/provider_app/lib/main.dart",
      "toolArgs": [
        "--dart-define=API_URL=http://127.0.0.1:4200/api"
      ]
    },
    {
      "name": "Node: Express Server (Cloud/Healthcare)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server.js",
      "restart": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "development",
        "PORT": "4200",
        "SKIP_HEALTHCARE_PROVISION": "false"
      }
    },
    {
      "name": "Node: Express Server (Offline/Mock)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server.js",
      "restart": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "env": {
        "NODE_ENV": "development",
        "PORT": "4200",
        "SKIP_HEALTHCARE_PROVISION": "true",
        "GEMINI_API_KEY": "offline_dummy_key_for_testing"
      }
    },
    {
      "name": "Web: Launch Chrome against Localhost",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}",
      "userDataDir": true
    },
    {
      "name": "Web: Attach to Existing Chrome (Port 9222)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Web: Launch Docs (Astro Study)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4321",
      "webRoot": "${workspaceFolder}/docs/study",
      "userDataDir": true
    },
    {
      "name": "Theme Debug: 🌊 Ocean Pool Float (?theme=pool)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200/?theme=pool",
      "webRoot": "${workspaceFolder}",
      "userDataDir": true
    },
    {
