# Pocket Gull FastAPI Sidecar — Environment
# Copy to .env and fill in values.
# Loaded automatically by uvicorn via python-dotenv.

# CORS origin for the Angular frontend (dev)
FRONTEND_ORIGIN=http://localhost:4000

# Path override for HDF5 data files (defaults to pocketgull_api/data/)
# HDF5_DATA_DIR=/path/to/biosignal/archive

# Path override for ML model (defaults to pocketgull_api/models/clinical_risk_v2.joblib)
# RISK_MODEL_PATH=/path/to/model.joblib
