{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "",
  "projects": {
    "app": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "./",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": {
              "base": "./dist",
              "browser": "."
            },
            "browser": "main.ts",
            "index": "index.html",
            "tsConfig": "tsconfig.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "public/docs",
                "output": "/docs"
              },
              {
                "glob": "robots.txt",
                "input": "src",
                "output": "/"
              },
              {
                "glob": "**/*",
                "input": "src/.well-known",
                "output": "/.well-known"
              },
              {
                "glob": "manifest.webmanifest",
                "input": "public",
                "output": "/"
              },
              {
                "glob": "**/*",
                "input": "src/assets/icons",
                "output": "/icons"
              }
            ],
            "styles": [
              "src/styles.css"
            ],
            "allowedCommonJsDependencies": [
              "crypto-js",
              "p-retry",
              "core-js",
              "raf",
              "rgbcolor",
              "html2canvas",
              "google-auth-library",
              "debug",
              "agent-base",
              "node-domexception",
              "web-streams-polyfill"
            ],
            "externalDependencies": [
              "@mikro-orm/sqlite",
              "@google-cloud/opentelemetry-cloud-monitoring-exporter",
              "@google-cloud/opentelemetry-cloud-trace-exporter",
              "@opentelemetry/resource-detector-gcp",
              "@mikro-orm/mariadb",
              "@mikro-orm/mssql",
              "@mikro-orm/mysql",
              "@mikro-orm/postgresql",
              "@mikro-orm/core",
              "@opentelemetry/otlp-transformer",
              "express",
              "compression",
              "@google-cloud/secret-manager",
              "@google/generative-ai",
              "swagger-ui-express",
              "genkit",
              "@genkit-ai/googleai",
              "zod",
              "@google-cloud/vertexai",
              "@google-cloud/logging",
              "@google-cloud/bigquery",
              "@google-cloud/dlp",
              "http-proxy-middleware"
            ],
            "security": {
              "allowedHosts": [
                "localhost",
                "pocket-gall-444980566010.us-west1.run.app",
                "understory-315235665910.us-west1.run.app",
                "pocket-gall-315235665910.us-west1.run.app",
                "pocket-gull-793190615625.us-west1.run.app",
                "pocket-gull-v2-793190615625.us-west1.run.app",
                "pocketgull.app",
                "pocketgull.com",
                "pocketgall.app",
                "pocketgall.com",
                "pocketgal.app",
                "pocketgal.ai"
              ]
            },
            "server": "src/main.server.ts",
            "outputMode": "server",
            "ssr": {
              "entry": "src/server.ts"
            }
          },
          "configurations": {
            "production": {
              "outputHashing": "all",
              "sourceMap": true,
              "optimization": {
                "scripts": true,
                "styles": {
                  "minify": true,
                  "inlineCritical": true
                },
                "fonts": {
                  "inline": false
                }
              },
              "serviceWorker": "ngsw-config.json"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "options": {
            "port": 4200
          },
          "configurations": {
            "production": {
              "buildTarget": "app:build:production"
            },
            "development": {
              "buildTarget": "app:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {
    "analytics": "e9296bcc-7486-41c0-9d35-11e3d9f14f07"
  }
}